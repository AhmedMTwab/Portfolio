---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts
        .filter((post) => !post.data.draft)
        .map((post) => ({
            params: { slug: post.id },
            props: { post },
        }));
}

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) =>
    date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
---

<BaseLayout title={`${post.data.title} — Ahmed Eltwab`}>
  <div class="container">
    <article class="post">
      <a href="/#blog" class="back-link">← Back to writing</a>
      <header class="post-header">
        <div class="post-tags">
            {post.data.tags.map((t) => <span class="post-tag">{t}</span>)}
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-date">{formatDate(post.data.pubDate)}</div>
      </header>
      <div class="post-body">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .back-link {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    display: inline-block;
    margin: 1.5rem 0 1rem;
  }
  .back-link:hover {
    text-decoration: underline;
  }
  .post-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .post-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .post-tag {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--accent-dim);
    padding: 3px 9px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .post-title {
    font-size: 28px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
    letter-spacing: -0.5px;
    margin-bottom: 0.75rem;
  }
  .post-desc {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }
  .post-date {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
  }
  .post-body {
    color: var(--muted);
    line-height: 1.8;
    font-size: 15.5px;
  }
  .post-body :global(h1),
  .post-body :global(h2),
  .post-body :global(h3) {
    color: var(--text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .post-body :global(h1) {
    font-size: 24px;
  }
  .post-body :global(h2) {
    font-size: 20px;
  }
  .post-body :global(h3) {
    font-size: 17px;
  }
  .post-body :global(p) {
    margin-bottom: 1rem;
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .post-body :global(li) {
    margin-bottom: 0.4rem;
  }
  .post-body :global(strong) {
    color: var(--text);
    font-weight: 500;
  }
  .post-body :global(code) {
    font-family: var(--mono);
    background: var(--surface);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    border: 1px solid var(--border);
  }
  .post-body :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }
  .post-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--text);
  }
</style>