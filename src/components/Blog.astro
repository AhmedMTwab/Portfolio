---
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const publishedPosts = posts
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
    date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
    });
---

<section id="blog" class="reveal">
  <div class="section-header">
    <span class="section-tag">blog</span>
    <h2 class="section-title">Writing</h2>
  </div>
  <div class="blog-grid">
    {publishedPosts.map((post) => (
      <a href={`/blog/${post.id}/`} class="blog-card">
        <div class="blog-cat">{post.data.tags[0] ?? "Writing"}</div>
        <div class="blog-title">{post.data.title}</div>
        <div class="blog-date">{formatDate(post.data.pubDate)}</div>
      </a>
    ))}
  </div>
  <div class="blog-more"><a href="/blog/">See all posts →</a></div>
</section>