---
const meta = [
    {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>`,
        label: "Cairo, Egypt",
    },
    {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>`,
        label: "ahmedmtwab@gmail.com",
    },
    {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>`,
        label: "+201500065985",
    },
    {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>`,
        label: "B.Sc. Computer Engineering · 2024",
    },
];

const cards = [
    { val: "~1 yr", label: "professional experience at EMPC" },
    { val: "2,300+", label: "employees served by the VMS" },
    { val: "4+", label: "shipped projects, 1 live in prod" },
];
---

<section id="hero">
  <div class="hero-status">
    <span class="hero-status-dot"></span>
    Open to new roles — Cairo or remote
  </div>
  <h1 class="hero-name">Ahmed Eltwab<span class="cursor"></span></h1>
  <p class="hero-title">.NET Backend Developer</p>
  <p class="hero-tagline">
    I build <strong>production-grade APIs</strong> with ASP.NET Core, EF Core, and SQL Server —
    with consistent attention to <strong>system quality, clean architecture, and data integrity</strong>.
    Based in Cairo. Available immediately.
  </p>

  <div class="hero-cards">
    {cards.map((c) => (
      <div class="hero-card">
        <div class="hero-card-val">{c.val}</div>
        <div class="hero-card-label">{c.label}</div>
      </div>
    ))}
  </div>

  <div class="hero-meta">
    {meta.map((m) => (
      <div class="hero-meta-item">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={m.icon}></svg>
        {m.label}
      </div>
    ))}
  </div>

  <div class="hero-ctas">
    <a href="/cv.pdf" download class="btn-primary">Download CV</a>
    <a href="#projects" class="btn-ghost">See projects</a>
    <a href="#blog" class="btn-ghost">Read the blog</a>
  </div>
</section>
